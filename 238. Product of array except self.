class Solution {
    public int[] productExceptSelf(int[] nums) {
        int n=nums.length;
        int p[]=new int[n];
    p[0]=nums[0];
        for(int i=1;i<n;i++){
            p[i]=p[i-1]*nums[i] ;           
        }
        int s[]=new int[n];
         s[n-1]=nums[n-1];
        for(int i=n-2;i>=0;i--){
            s[i]=s[i+1]*nums[i]
;        }
        int a[]=new int[n];
        for(int i=0;i<n;i++){
            int l=(i==0)?1:p[i-1];
            int r=(i==n-1)?1:s[i+1];
            a[i]=(l*r);
        }
        return a;
        
    }
}
