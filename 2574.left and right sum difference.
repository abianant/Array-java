class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n=nums.length;
        int ls[]=new int[n];
        int rs[]=new int[n];
        ls[0]=nums[0];
        rs[n-1]=nums[n-1];
        for(int i=1;i<n;i++){
            ls[i]=nums[i]+ls[i-1];
        }
        for(int i=n-2;i>0;i--){
            rs[i]=nums[i]+rs[i+1];
        }
        int ans[]=new int[n];
        for(int i=0;i<n;i++){
            int l=(i==0)?0:ls[i-1];
            int r=(i==n-1)?0:rs[i+1];
            ans[i]=Math.abs(l-r) ;
                           }  
                           return ans;                 }
            

        
        
    }
