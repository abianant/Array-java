import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int [][]a=new int[n][n];
        for(int i=0;i<n;i++)
        {
            for(int j=0;j<n;j++)
            {
                a[i][j]=sc.nextInt();
            }
        }
        int fr=0;
        int b=0;
        for(int i=0;i<n;i++){
            for(int j=0;j<n;j++){
                 if(i==j)
                {
                    fr+=a[i][j];
                }
                 if(i+j==n-1)
            {
                b+=a[i][j];
            } 
            }}
            if(fr==b)
            System.out.print("Yes");  
            else
            {
                System.out.print("No");
            }
            
            }
        }
        
